{
  "name": "api",
  "version": "1.0.0",
  "description": "Zero-Trust Professional Network backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:infra": "npm run infra:up && npm run dev",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed:large": "node scripts/seed-large-data.cjs",
    "seed:large:append": "node scripts/seed-large-data.cjs --append",
    "infra:up": "docker compose up -d postgres redis rust-service",
    "infra:down": "docker compose down",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "rust:dev": "cargo run --manifest-path rust-service/Cargo.toml",
    "rust:build": "cargo build --manifest-path rust-service/Cargo.toml"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.5",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prisma": "^7.7.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}