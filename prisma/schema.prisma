generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String?
  currentRole  String?
  location     String?
  headline     String?
  about        String?
  profileImageUrl String?
  profileBannerUrl String?
  publicProfileUrl String? @unique
  trustScore   Int       @default(0)
  createdAt    DateTime  @default(now())

  sessions      Session[]
  experiences   Experience[]
  skills        Skill[]
  verifications Verification[]
  sentConnections Connection[] @relation("Requester")
  receivedConnections Connection[] @relation("Receiver")
  following     Follow[]  @relation("FollowerUser")
  followers     Follow[]  @relation("FollowingUser")
  posts         Post[]
  likes         Like[]
  comments      Comment[]
  notifications Notification[]
  participants  Participant[]
  sentMessages  Message[]      @relation("SentMessages")
  profileReportsFiled    ProfileReport[] @relation("ProfileReportReporter")
  profileReportsReceived ProfileReport[] @relation("ProfileReportTarget")
  postedJobs    Job[]
  applications  Application[]
  profileViewsGiven    ProfileView[] @relation("ProfileViewer")
  profileViewsReceived ProfileView[] @relation("ProfileViewed")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("FollowerUser", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("FollowingUser", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, refreshToken])
}

model Experience {
  id          String           @id @default(uuid())
  userId      String
  companyName String
  role        String
  description String?
  status      ExperienceStatus @default(SELF_CLAIMED)
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime         @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifacts Artifact[]
  verifications Verification[]

  @@index([userId])
}

model Verification {
  id           String             @id @default(uuid())
  experienceId String
  verifierId   String
  status       VerificationStatus @default(PENDING)
  createdAt    DateTime           @default(now())

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  verifier   User       @relation(fields: [verifierId], references: [id], onDelete: Cascade)

  @@index([experienceId])
  @@index([verifierId])
  @@unique([experienceId, verifierId])
}

model Connection {
  id           String           @id @default(uuid())
  requesterId  String
  receiverId   String
  relationship RelationshipType
  status       ConnectionStatus @default(PENDING)
  createdAt    DateTime         @default(now())

  requester User @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([requesterId])
  @@index([receiverId])
}

model Post {
  id        String   @id @default(uuid())
  userId    String
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    Like[]
  comments Comment[]

  @@index([userId])
  @@index([createdAt])
}

model Like {
  id     String @id @default(uuid())
  userId String
  postId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model Artifact {
  id           String       @id @default(uuid())
  experienceId String
  type         ArtifactType
  url          String
  createdAt    DateTime     @default(now())

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@index([experienceId])
}

model Skill {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, name])
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  participants Participant[]
  messages     Message[]

  @@index([createdAt])
}

model Participant {
  id             String @id @default(uuid())
  userId         String
  conversationId String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String   @id @default(uuid())
  senderId       String
  conversationId String
  content        String
  createdAt      DateTime @default(now())

  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([conversationId])
  @@index([conversationId, createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead, createdAt])
}

model ProfileView {
  id           String   @id @default(uuid())
  viewerId     String
  viewedUserId String
  createdAt    DateTime @default(now())

  viewer     User @relation("ProfileViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  viewedUser User @relation("ProfileViewed", fields: [viewedUserId], references: [id], onDelete: Cascade)

  @@index([viewerId, createdAt])
  @@index([viewedUserId, createdAt])
  @@index([viewerId, viewedUserId, createdAt])
}

model ProfileReport {
  id             String              @id @default(uuid())
  reporterId     String
  reportedUserId String
  reason         ProfileReportReason
  details        String?
  status         ProfileReportStatus @default(OPEN)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  reporter     User @relation("ProfileReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User @relation("ProfileReportTarget", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@unique([reporterId, reportedUserId])
  @@index([reporterId, createdAt])
  @@index([reportedUserId, createdAt])
  @@index([status, createdAt])
}

model Job {
  id          String   @id @default(uuid())
  title       String
  description String
  location    String?
  createdAt   DateTime @default(now())
  postedById  String

  postedBy     User          @relation(fields: [postedById], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([postedById])
  @@index([createdAt])
}

model Application {
  id        String            @id @default(uuid())
  jobId     String
  userId    String
  status    ApplicationStatus @default(APPLIED)
  createdAt DateTime          @default(now())

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
  @@index([status])
}

enum ExperienceStatus {
  SELF_CLAIMED
  PEER_VERIFIED
  FULLY_VERIFIED
  FLAGGED
}

enum ArtifactType {
  GITHUB
  PORTFOLIO
  PROJECT
  CERTIFICATE
  OTHER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  REJECTED
  HIRED
}

enum RelationshipType {
  COWORKER
  TEAMMATE
  INTERVIEWED_WITH
  EVENT
  COLD_OUTREACH
}

enum NotificationType {
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  VERIFICATION_REQUEST
  VERIFICATION_APPROVED
  MESSAGE_RECEIVED
  POST_LIKED
  POST_COMMENTED
  JOB_APPLIED
  APPLICATION_STATUS_UPDATED
  PROFILE_VIEWED
}

enum ProfileReportReason {
  SPAM
  IMPERSONATION
  HARASSMENT
  MISINFORMATION
  INAPPROPRIATE
  OTHER
}

enum ProfileReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}
